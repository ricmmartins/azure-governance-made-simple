<mxfile>
  <diagram name="Machine Configuration Flow" id="mc-flow-1">
    <mxGraphModel dx="1000" dy="200" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1000" pageHeight="200">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="mc-s1" value="Azure Policy&#xa;Assignment" style="rounded=1;whiteSpace=wrap;fillColor=#4A90D9;fontColor=#FFFFFF;strokeColor=#3A7BC8;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="20" y="60" width="180" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="mc-s2" value="Machine Configuration&#xa;Extension (on VM)" style="rounded=1;whiteSpace=wrap;fillColor=#2C3E50;fontColor=#FFFFFF;strokeColor=#1A252F;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="260" y="60" width="200" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="mc-s3" value="Evaluates DSC&#xa;Configuration" style="rounded=1;whiteSpace=wrap;fillColor=#FFF3CD;strokeColor=#F0C040;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="520" y="60" width="180" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="mc-s4" value="Reports Compliance&#xa;to Azure Policy" style="rounded=1;whiteSpace=wrap;fillColor=#D5F5E3;strokeColor=#58D68D;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="760" y="60" width="200" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="mc-e1" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#333333;strokeWidth=2;" edge="1" source="mc-s1" target="mc-s2" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="mc-e2" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#333333;strokeWidth=2;" edge="1" source="mc-s2" target="mc-s3" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="mc-e3" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#333333;strokeWidth=2;" edge="1" source="mc-s3" target="mc-s4" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
