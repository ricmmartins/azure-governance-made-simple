        </mxCell>
        <mxCell id="chip_require_desc" value="Denies deployment if Environment, Owner, CostCenter tags are missing" style="text;align=left;verticalAlign=middle;fontSize=9;fontColor=#CCCCCC;whiteSpace=wrap;" vertex="1" parent="left_panel">
          <mxGeometry x="45.0" y="258.0" width="380" height="25" as="geometry" />
