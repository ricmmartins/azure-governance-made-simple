        </mxCell>
        <mxCell id="chip_deny" value="🚫 Deny non-matching names" style="rounded=1;whiteSpace=wrap;fillColor=#E74C3C;fontColor=#FFFFFF;strokeColor=#C0392B;fontSize=11;fontStyle=1;" vertex="1" parent="left_panel">
          <mxGeometry x="45.0" y="75.0" width="380" height="40" as="geometry" />
        </mxCell>
        <mxCell id="chip_deny_desc" value="Blocks resource creation if name doesn't match pattern (e.g., rg-*-prod-*)" style="text;align=left;verticalAlign=middle;fontSize=9;fontColor=#CCCCCC;whiteSpace=wrap;" vertex="1" parent="left_panel">
          <mxGeometry x="45.0" y="138.0" width="380" height="25" as="geometry" />
        </mxCell>
        <mxCell id="chip_require" value="⚠️ Require mandatory tags" style="rounded=1;whiteSpace=wrap;fillColor=#F9A825;fontColor=#333333;strokeColor=#C17900;fontSize=11;fontStyle=1;" vertex="1" parent="left_panel">
