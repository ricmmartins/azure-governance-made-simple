<?xml version='1.0' encoding='UTF-8'?>
<mxfile>
  <diagram name="Naming Tagging Architecture" id="nta-1">
    <mxGraphModel dx="1100" dy="500" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1100" pageHeight="500" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="left_panel" value="Azure Policy (Enforcement Layer)" style="swimlane;startSize=30;fillColor=#2C3E50;fontColor=#FFFFFF;strokeColor=#1A252F;fontSize=13;fontStyle=1;rounded=1;" vertex="1" parent="1">
